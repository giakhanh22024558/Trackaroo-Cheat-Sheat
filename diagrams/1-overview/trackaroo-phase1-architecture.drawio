        <mxCell id="ARR_EDGE5" value="&lt;i&gt;Phase 2 inert&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;dashPattern=5 3;strokeColor=#9e9e9e;strokeWidth=1;fontColor=#616161;fontSize=10;labelBackgroundColor=#ffffff;" parent="SEC_ARROWS" source="ARR_A5" target="ARR_B5" edge="1">
          <mxGeometry relative="1" as="geometry" />
