  <diagram id="legend-page" name="Legend">
    <mxGraphModel dx="1181" dy="1567" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="0" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1300" background="#eceff1" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="LEG_TITLE" value="&lt;b&gt;LEGEND — Diagram Visual Vocabulary&lt;/b&gt;&lt;br/&gt;&lt;i&gt;trackaroo® Phase 1 Architecture Diagram&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="30" width="1120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="SEC_SHAPES" value="&lt;b&gt;Shape Vocabulary&lt;/b&gt;&lt;br/&gt;&lt;i&gt;4 shapes only — Rectangle covers anything not pipeline/data store/external&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#424242;strokeWidth=1.5;verticalAlign=top;fontSize=13;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;container=1;collapsible=0;recursiveResize=0;expand=0;" parent="1" vertex="1">
          <mxGeometry x="40" y="110" width="560" height="330" as="geometry" />
        </mxCell>
        <mxCell id="SHAPE_RECT" value="Component" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=11;spacing=5;" parent="SEC_SHAPES" vertex="1">
          <mxGeometry x="30" y="65" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="SHAPE_RECT_DESC" value="&lt;b&gt;Rectangle&lt;/b&gt; — Generic component / on-device feature / UI module / governance gateway / published content. The default — covers everything that isn&#39;t a pipeline stage, data store, or external provider.&lt;br/&gt;&lt;i&gt;Used for: TM, FA, NAV, BT, HT, SOS, EVT, SAP, CAL, MTT, PRESETS, PCRFW, OCS modules (incl. Verification: TDGA/FACA/AUDIT), Companion Website.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_SHAPES" vertex="1">
          <mxGeometry x="170" y="60" width="370" height="60" as="geometry" />
        </mxCell>
        <mxCell id="SHAPE_DB" value="Data store" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#ffffff;strokeColor=#5e35b2;strokeWidth=1;fontSize=11;spacing=5;" parent="SEC_SHAPES" vertex="1">
          <mxGeometry x="30" y="130" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="SHAPE_DB_DESC" value="&lt;b&gt;Cylinder&lt;/b&gt; — Data store / database.&lt;br/&gt;&lt;i&gt;Used for: raw_ingested_tracks, track_review_queue, production_tracks (PostgreSQL), Firestore, Firestore Local Cache, Encrypted SQLite/WAL.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_SHAPES" vertex="1">
          <mxGeometry x="170" y="125" width="370" height="60" as="geometry" />
        </mxCell>
        <mxCell id="SHAPE_PROC" value="Pipeline stage" style="shape=process;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5e35b2;strokeWidth=1;fontSize=11;spacing=5;" parent="SEC_SHAPES" vertex="1">
          <mxGeometry x="30" y="195" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="SHAPE_PROC_DESC" value="&lt;b&gt;Process box&lt;/b&gt; (rect with double vertical lines) — Pipeline transformation / data processing stage. Inspired by BPMN subroutine notation.&lt;br/&gt;&lt;i&gt;Used for: TrackIQ pipeline stages — Ingestion Adapter, DEM Enrichment, Scoring Engine, Tile Generator.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_SHAPES" vertex="1">
          <mxGeometry x="170" y="190" width="370" height="60" as="geometry" />
        </mxCell>
        <mxCell id="SHAPE_EXT" value="External provider" style="rounded=1;arcSize=80;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e65100;strokeWidth=1;fontSize=11;spacing=5;" parent="SEC_SHAPES" vertex="1">
          <mxGeometry x="30" y="260" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="SHAPE_EXT_DESC" value="&lt;b&gt;Stadium / Pill&lt;/b&gt; — External provider / third-party actor (boundary signal). Inspired by Yourdon-Coad DFD external entity.&lt;br/&gt;&lt;i&gt;Used for: Mapbox, Track Data Feeds, DEM Sources, Authority Hazard Feeds (BOM/AFAC), LoRa peripherals, External GPS.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_SHAPES" vertex="1">
          <mxGeometry x="190" y="255" width="350" height="60" as="geometry" />
        </mxCell>
        <mxCell id="SEC_ARROWS" value="&lt;b&gt;Arrow Vocabulary&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Style + color encodes semantic relationship&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#424242;strokeWidth=1.5;verticalAlign=top;fontSize=13;fontStyle=1;align=left;spacingLeft=10;spacingTop=6;container=1;collapsible=0;recursiveResize=0;expand=0;" parent="1" vertex="1">
          <mxGeometry x="620" y="110" width="540" height="590" as="geometry" />
        </mxCell>
        <mxCell id="ARR_A1" value="A" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;fontSize=10;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="30" y="65" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ARR_B1" value="B" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;fontSize=10;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="200" y="65" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ARR_EDGE1" value="Verb action" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" parent="SEC_ARROWS" source="ARR_A1" target="ARR_B1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ARR_DESC1" value="&lt;b&gt;Solid arrow + verb label&lt;/b&gt; — Control / operational relationship.&lt;br/&gt;&lt;i&gt;Source performs action on target. e.g. &quot;Surfaces scoring pipeline&quot;, &quot;Approves or rejects&quot;, &quot;Pairs LoRa mesh nodes&quot;.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="250" y="55" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ARR_A2" value="A" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;fontSize=10;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="30" y="135" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ARR_B2" value="B" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;fontSize=10;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="200" y="135" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ARR_EDGE2" value="&lt;b&gt;Data noun&lt;/b&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;dashPattern=2 3;strokeColor=#6a1b9a;strokeWidth=2;fontColor=#6a1b9a;fontSize=10;labelBackgroundColor=#ffffff;" parent="SEC_ARROWS" source="ARR_A2" target="ARR_B2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ARR_DESC2" value="&lt;b&gt;Purple dotted arrow + noun label&lt;/b&gt; — Data payload flow.&lt;br/&gt;&lt;i&gt;Label names the data flowing (not the action). e.g. &quot;TrackSegmentGroup&quot;, &quot;Proposed Grade Event&quot;, &quot;Tile manifest&quot;, &quot;TrackIQ Scoring Data&quot;.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="250" y="125" width="280" height="50" as="geometry" />
