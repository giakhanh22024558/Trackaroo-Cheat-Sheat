        <mxCell id="COL_OCS" value="&lt;b&gt;OCS-5026 WEB APP&lt;/b&gt;&lt;br/&gt;Operations Console" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b2dfdb;strokeColor=#00695c;strokeWidth=2;fontSize=10;" parent="SEC_COLORS" vertex="1">
