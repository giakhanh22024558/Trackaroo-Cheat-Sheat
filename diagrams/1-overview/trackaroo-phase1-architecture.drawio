        <mxCell id="ARR_DESC5" value="&lt;b&gt;Grey dashed arrow&lt;/b&gt; — Phase 2 scaffold / inert in Phase 1.&lt;br/&gt;&lt;i&gt;Marks future capabilities placeholder. e.g. &quot;Phase 2 high-accuracy GNSS (inert)&quot;.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="250" y="335" width="280" height="50" as="geometry" />
