          <mxGeometry x="200" y="205" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ARR_EDGE3" value="R / W" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;startArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;" parent="SEC_ARROWS" source="ARR_A3" target="ARR_B3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ARR_DESC3" value="&lt;b&gt;Bidirectional arrow&lt;/b&gt; — Read / Write relationship.&lt;br/&gt;&lt;i&gt;Used for app ↔ local cache, core ↔ SQLite. Label like &quot;Reads / Writes app data&quot;.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="250" y="195" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ARR_A4" value="A" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;fontSize=10;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="30" y="275" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ARR_B4" value="B" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;fontSize=10;" parent="SEC_ARROWS" vertex="1">
          <mxGeometry x="200" y="275" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ARR_EDGE4" value="&lt;b&gt;[X] PROHIBITED&lt;/b&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;dashPattern=5 5;strokeColor=#c62828;strokeWidth=2;fontColor=#c62828;fontSize=10;labelBackgroundColor=#ffffff;" parent="SEC_ARROWS" source="ARR_A4" target="ARR_B4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ARR_DESC4" value="&lt;b&gt;Red dashed arrow&lt;/b&gt; — Architecturally PROHIBITED path.&lt;br/&gt;&lt;i&gt;Marks forbidden data/control flow that vendor must NOT implement. e.g. &quot;SQLite never syncs to cloud&quot;, &quot;Core data never leaves device&quot;.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" parent="SEC_ARROWS" vertex="1">
