        <mxCell id="COL_CBE" value="&lt;b&gt;CLOUD BACKEND&lt;/b&gt;&lt;br/&gt;Compute + database" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d1c4e9;strokeColor=#5e35b2;strokeWidth=2;fontSize=10;" parent="SEC_COLORS" vertex="1">
