        <mxCell id="COL_MOB" value="&lt;b&gt;MOBILE APP&lt;/b&gt;&lt;br/&gt;Flutter dual-layer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#0277bd;strokeWidth=2;fontSize=10;" parent="SEC_COLORS" vertex="1">
