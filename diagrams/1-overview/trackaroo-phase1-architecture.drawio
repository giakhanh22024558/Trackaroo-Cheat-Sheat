        <mxCell id="COL_EXT" value="&lt;b&gt;EXTERNAL&lt;/b&gt;&lt;br/&gt;Third-party providers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=2;fontSize=10;" parent="SEC_COLORS" vertex="1">
