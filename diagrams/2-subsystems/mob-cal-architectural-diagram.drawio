                </mxCell>
                <mxCell id="SFM" value="&lt;i&gt;MOB-1101.SFM&lt;/i&gt; · &lt;b&gt;State Flag Manager&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Owns 4 flags:&lt;/i&gt;&lt;br/&gt;• satReady (always F)&lt;br/&gt;• queueEnabled&lt;br/&gt;• offlineBeacon&lt;br/&gt;• partialSignal&lt;br/&gt;&lt;i&gt;Computes state transitions deterministically&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" parent="CAL" vertex="1">
                    <mxGeometry x="15" y="85" width="277" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="LMON" value="&lt;i&gt;MOB-1101.LMON&lt;/i&gt; · &lt;b&gt;Latency Monitor&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Tracks discovery + propagation latency from MTT&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Compares vs M6 threshold (provisional · vendor input pending)&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Reports to SFM · never flips flags directly&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" parent="CAL" vertex="1">
                    <mxGeometry x="370" y="85" width="277" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="TR" value="&lt;i&gt;MOB-1101.TR&lt;/i&gt; · &lt;b&gt;Transport Router&lt;/b&gt;&lt;br/&gt;&lt;i&gt;5-rule priority (M5 Locked-in):&lt;/i&gt;&lt;br/&gt;1. Sat (Phase 2 · inert)&lt;br/&gt;2. BLE Mesh&lt;br/&gt;3. Wi-Fi Direct&lt;br/&gt;4. LoRa&lt;br/&gt;5. Queue (fallback)&lt;br/&gt;&lt;i&gt;Read-only on SFM state · selects tier per packet&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" parent="CAL" vertex="1">
                    <mxGeometry x="720" y="85" width="277" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="QMGR" value="&lt;i&gt;MOB-1101.QMGR&lt;/i&gt; · &lt;b&gt;Queue Manager&lt;/b&gt;&lt;br/&gt;&lt;i&gt;WAL · AES-256 · crash-survivable&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Firebase-independent (M0f)&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Reads queueEnabled flag · writes/replays via comms_queue schema in MOB-3002 SQL&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" parent="CAL" vertex="1">
                    <mxGeometry x="1080" y="85" width="277" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="SPUB" value="&lt;i&gt;MOB-1101.SPUB&lt;/i&gt; · &lt;b&gt;UI Status Publisher&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Emits state label per UXS-5726 (≤2s repaint):&lt;/i&gt;&lt;br/&gt;• &quot;Beacon active&quot; (S3)&lt;br/&gt;• &quot;Limited Connectivity&quot; (S4)&lt;br/&gt;• &quot;Queue pending&quot; (S5)&lt;br/&gt;• &quot;Offline&quot; (S5 no peers)&lt;br/&gt;&lt;i&gt;Calm-language enforced — no &quot;Reconnecting…&quot;&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" parent="CAL" vertex="1">
                    <mxGeometry x="1390" y="85" width="277" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="MTT" value="&lt;i&gt;MOB-1102&lt;/i&gt; · &lt;b&gt;Multi-Tier Transport (MTT)&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Implements ITransport adapter for each tier — BLE Mesh · Wi-Fi Direct · LoRa · Sat adapter slot (Phase 2 only · no implementing class in Phase 1) · Reports peer-discovery + latency to CAL&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;verticalAlign=middle;" parent="MOB_G2" vertex="1">
