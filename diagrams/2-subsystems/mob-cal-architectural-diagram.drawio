    <diagram id="cal-state-machine" name="CAL · State Machine + Flag Transitions">
        <mxGraphModel dx="2294" dy="1793" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="TITLE" value="&lt;b&gt;CAL State Machine — 5 Reachable States + 4 Mandatory Flag Transitions&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Each state shows flag vector [satReady · queueEnabled · offlineBeacon · partialSignal]. Transitions labeled with trigger + flags that change. Behavioral view — companion to Page 1 Component Architecture.&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="-130" y="-20" width="1760" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="S0" value="&lt;b&gt;S0 · AppLaunch&lt;/b&gt;&lt;br/&gt;&lt;i&gt;flags = [F, F, F, F]&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Pre-session · CAL initialized&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#455a64;strokeWidth=2;fontSize=11;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="-50" y="180" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="S1" value="&lt;b&gt;S1 · Idle&lt;/b&gt;&lt;br/&gt;&lt;i&gt;flags = [F, F, F, F]&lt;/i&gt;&lt;br/&gt;&lt;i&gt;TrackMate not running&lt;/i&gt;&lt;br/&gt;&lt;b&gt;UI: hidden&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#cfd8dc;strokeColor=#455a64;strokeWidth=2;fontSize=11;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="310" y="180" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="S2" value="&lt;b&gt;S2 · SessionActive&lt;/b&gt; &lt;i&gt;(transient)&lt;/i&gt;&lt;br/&gt;&lt;i&gt;flags = [F, T, ?, ?]&lt;/i&gt;&lt;br/&gt;&lt;i&gt;queueEnabled just flipped ON&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Resolving... (≤2s)&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=2;fontSize=11;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="700" y="180" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="S3" value="&lt;b&gt;S3 · BeaconingFull&lt;/b&gt;&lt;br/&gt;&lt;i&gt;flags = [F, T, T, F]&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Peer + low latency&lt;/i&gt;&lt;br/&gt;&lt;b&gt;UI: &amp;quot;Beacon active&amp;quot;&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;strokeWidth=2.5;fontSize=11;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="380" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="S4" value="&lt;b&gt;S4 · BeaconingPartial&lt;/b&gt;&lt;br&gt;&lt;i&gt;flags = [F, T, T, T]&lt;/i&gt;&lt;br&gt;&lt;i&gt;Peer + high latency&lt;/i&gt;&lt;div&gt;&lt;i&gt;use BLE Mesh&lt;br&gt;&lt;/i&gt;&lt;b&gt;UI: &quot;Limited Connectivity&quot;&lt;/b&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;strokeWidth=2.5;fontSize=11;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="380" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="S5" value="&lt;b&gt;S5 · QueueOnly&lt;/b&gt;&lt;br/&gt;&lt;i&gt;flags = [F, T, F, F]&lt;/i&gt;&lt;br/&gt;&lt;i&gt;No peer reachable · queue holds&lt;/i&gt;&lt;br/&gt;&lt;b&gt;UI: &amp;quot;Queue pending&amp;quot; / &amp;quot;Offline&amp;quot;&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8bbd0;strokeColor=#ad1457;strokeWidth=2.5;fontSize=11;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="380" y="540" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="START" value="●" style="ellipse;whiteSpace=wrap;html=1;fillColor=#263238;strokeColor=#263238;strokeWidth=2;fontColor=#ffffff;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="45" y="100" width="30" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="e_start_s0" value="" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#263238;strokeWidth=2;" parent="1" source="START" target="S0" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_s0_s1" value="&lt;b&gt;process init complete&lt;/b&gt;&lt;br/&gt;&lt;i&gt;all flags stay F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#455a64;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="S0" target="S1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_s1_s2" value="&lt;b&gt;user starts TrackMate&lt;/b&gt;&lt;br/&gt;&lt;i&gt;queueEnabled: F → T&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#455a64;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="S1" target="S2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_s2_s3" value="&lt;b&gt;peer + latency &amp;lt; threshold&lt;/b&gt;&lt;br/&gt;&lt;i&gt;offlineBeacon: F → T&lt;/i&gt;&lt;br/&gt;&lt;i&gt;partialSignal: stays F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2e7d32;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="S2" target="S3" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1130" y="260"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_s2_s4" value="&lt;b&gt;peer + latency &amp;gt; threshold&lt;/b&gt;&lt;br/&gt;&lt;i&gt;offlineBeacon: F → T&lt;/i&gt;&lt;br/&gt;&lt;i&gt;partialSignal: F → T&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#e65100;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="S2" target="S4" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1500" y="210"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_s2_s5" value="&lt;b&gt;no peer found in window&lt;/b&gt;&lt;br/&gt;&lt;i&gt;offlineBeacon: stays F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#ad1457;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="S2" target="S5" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="810" y="560"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_s3_s4" value="&lt;b&gt;latency degrades&lt;/b&gt;&lt;br/&gt;&lt;i&gt;partialSignal: F → T&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#e65100;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" parent="1" source="S3" target="S4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_s4_s3" value="&lt;b&gt;latency recovers (debounced)&lt;/b&gt;&lt;br/&gt;&lt;i&gt;partialSignal: T → F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2e7d32;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;exitX=0;exitY=0.7;entryX=1;entryY=0.7;" parent="1" source="S4" target="S3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_s3_s5" value="&lt;b&gt;all peers lost&lt;/b&gt;&lt;br/&gt;&lt;i&gt;offlineBeacon: T → F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#ad1457;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="S3" target="S5" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="520" y="430"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_s4_s5" value="&lt;b&gt;all peers lost&lt;/b&gt;&lt;br/&gt;&lt;i&gt;offlineBeacon: T → F&lt;/i&gt;&lt;br/&gt;&lt;i&gt;partialSignal: T → F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#ad1457;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="S4" target="S5" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1540" y="680"/>
                            <mxPoint x="490" y="680"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_s5_s3" value="&lt;b&gt;new peer + low latency&lt;/b&gt;&lt;br/&gt;&lt;i&gt;offlineBeacon: F → T&lt;/i&gt;&lt;br/&gt;&lt;i&gt;queue flushes&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2e7d32;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" parent="1" source="S5" target="S3" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1130" y="630"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_s3_s1" value="&lt;b&gt;user stops session&lt;/b&gt;&lt;br/&gt;&lt;i&gt;queueEnabled: T → F&lt;br/&gt;offlineBeacon: T → F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#607d8b;strokeWidth=1.5;dashed=1;dashPattern=8 4;fontSize=9;labelBackgroundColor=#ffffff;" parent="1" source="S3" target="S1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1190" y="130"/>
                            <mxPoint x="450" y="130"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_s4_s1" value="&lt;b&gt;user stops session&lt;/b&gt;&lt;br/&gt;&lt;i&gt;all 3 active flags → F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#607d8b;strokeWidth=1.5;dashed=1;dashPattern=8 4;fontSize=9;labelBackgroundColor=#ffffff;" parent="1" source="S4" target="S1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1580" y="100"/>
                            <mxPoint x="370" y="100"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e_s5_s1" value="&lt;b&gt;user stops session&lt;/b&gt;&lt;br/&gt;&lt;i&gt;queueEnabled: T → F&lt;/i&gt;" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#607d8b;strokeWidth=1.5;dashed=1;dashPattern=8 4;fontSize=9;labelBackgroundColor=#ffffff;" parent="1" source="S5" target="S1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="450" y="410"/>
                            <mxPoint x="450" y="410"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="INV_LEGEND" value="&lt;b&gt;State invariants (always true)&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;1. &lt;b&gt;satReady = F&lt;/b&gt; in EVERY Phase-1 reachable state · CI gate enforced&lt;br/&gt;2. &lt;b&gt;queueEnabled = T&lt;/b&gt; iff TrackMate session active&lt;br/&gt;3. &lt;b&gt;offlineBeacon = T&lt;/b&gt; iff CAL in S3 or S4 (peer present)&lt;br/&gt;4. &lt;b&gt;partialSignal = T&lt;/b&gt; iff CAL in S4 only&lt;br/&gt;5. Transitions are &lt;b&gt;deterministic&lt;/b&gt; · same trigger → same next state (no ML / probabilistic)&lt;br/&gt;6. UI labels follow &lt;b&gt;Visual Calm&lt;/b&gt; doctrine — no &amp;quot;Reconnecting&amp;quot; / &amp;quot;Recovery in progress&amp;quot; language" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2e7d32;strokeWidth=1.5;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="80" y="780" width="460" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="FLAG_LEGEND" value="&lt;b&gt;Flag vector key&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;i&gt;[satReady · queueEnabled · offlineBeacon · partialSignal]&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;satReady&lt;/b&gt; — Phase-1 always F · Phase-2 only&lt;br/&gt;&lt;b&gt;queueEnabled&lt;/b&gt; — TrackMate session active&lt;br/&gt;&lt;b&gt;offlineBeacon&lt;/b&gt; — peer present + transmitting&lt;br/&gt;&lt;b&gt;partialSignal&lt;/b&gt; — latency above M6 threshold" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f57c00;strokeWidth=1.5;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="600" y="780" width="290" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="EDGE_LEGEND" value="&lt;b&gt;Transition edge colors&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;font color=&quot;#2e7d32&quot;&gt;━━━&lt;/font&gt; Green — entering &#39;good&#39; state (S3 BeaconingFull)&lt;br/&gt;&lt;font color=&quot;#e65100&quot;&gt;━━━&lt;/font&gt; Orange — entering degraded state (S4 BeaconingPartial)&lt;br/&gt;&lt;font color=&quot;#ad1457&quot;&gt;━━━&lt;/font&gt; Magenta — entering offline state (S5 QueueOnly)&lt;br/&gt;&lt;font color=&quot;#607d8b&quot;&gt;┄┄┄&lt;/font&gt; Grey dashed — session-stop teardown (→ S1 Idle)&lt;br/&gt;&lt;font color=&quot;#455a64&quot;&gt;━━━&lt;/font&gt; Slate — neutral transition (init / session-start)&lt;br/&gt;&lt;br/&gt;&lt;i&gt;Note: state-machine edge palette is page-2-specific (semantic state coloring). Page 1 component edges follow the master architecture Legend.&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#455a64;strokeWidth=1.5;fontSize=10;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="920" y="780" width="320" height="210" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>