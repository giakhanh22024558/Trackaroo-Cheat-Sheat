                <mxCell id="CAL" value="&lt;i&gt;MOB-1101&lt;/i&gt; · &lt;b&gt;Comms Abstraction Layer&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;background-color:#ffe082;color:#000;padding:1px 4px;font-size:8px;&quot;&gt;satReady = FALSE · Inactive in Phase 1.&lt;/span&gt;&lt;br/&gt;&lt;i&gt;5 internal components · Owns transport priority + 4 mandatory flags + UI state publication&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;dashed=1;dashPattern=3 2;verticalAlign=top;fontSize=11;fontStyle=1;align=left;spacingLeft=8;spacingTop=4;container=1;collapsible=0;recursiveResize=0;expand=0;" parent="MOB_G2" vertex="1">
