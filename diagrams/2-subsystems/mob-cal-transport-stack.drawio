    <diagram id="cal-transport-stack" name="CAL · Transport Stack">
        <mxGraphModel dx="2493" dy="1408" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
