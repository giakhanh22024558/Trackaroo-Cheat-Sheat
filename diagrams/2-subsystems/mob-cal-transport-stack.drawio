                    <mxGeometry x="20" y="40" width="250" height="125" as="geometry"/>
                </mxCell>
                <mxCell id="F2" value="&lt;b&gt;queueEnabled&lt;/b&gt;&lt;br/&gt;&lt;i&gt;session active?&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;True iff TrackMate session running" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1976d2;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="FLAGS">
                    <mxGeometry x="290" y="40" width="250" height="125" as="geometry"/>
                </mxCell>
                <mxCell id="F3" value="&lt;b&gt;offlineBeacon&lt;/b&gt;&lt;br/&gt;&lt;i&gt;peer present?&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;True iff CAL in S3 or S4" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1976d2;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="FLAGS">
                    <mxGeometry x="560" y="40" width="250" height="125" as="geometry"/>
                </mxCell>
                <mxCell id="F4" value="&lt;b&gt;partialSignal&lt;/b&gt;&lt;br/&gt;&lt;i&gt;latency &amp;gt; M6 threshold?&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;True iff CAL in S4 BeaconingPartial" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1976d2;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="FLAGS">
                    <mxGeometry x="830" y="40" width="250" height="125" as="geometry"/>
                </mxCell>
                <mxCell id="SEP" value="⚠ IMMUTABLE SEPARATION — Dart ⇄ Native boundary · MethodChannel-only · architecturally enforced" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#c62828;strokeWidth=3;dashed=1;dashPattern=8 4;fontColor=#b71c1c;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="20" y="475" width="1140" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="NATIVE" value="&lt;b&gt;NATIVE PLATFORM CHANNELS&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Tech: Swift (iOS) · Kotlin (Android) · platform-specific radio stacks&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#757575;strokeWidth=1.5;dashed=1;dashPattern=5 3;verticalAlign=top;fontSize=12;fontStyle=1;align=left;spacingLeft=8;spacingTop=4;container=1;collapsible=0;recursiveResize=0;expand=0;" vertex="1" parent="1">
                    <mxGeometry x="20" y="525" width="1140" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="BRIDGE" value="&lt;b&gt;MethodChannel Bridge&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Dart ⇄ Native — the only path across the boundary&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Encodes send / receive via platform channels&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="NATIVE">
                    <mxGeometry x="410" y="45" width="320" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ANDROID" value="&lt;b&gt;Android&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Kotlin · BLE Stack · Wi-Fi P2P&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;Native radio APIs exposed via Kotlin bridge handlers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="NATIVE">
                    <mxGeometry x="40" y="45" width="340" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="IOS" value="&lt;b&gt;iOS&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Swift · CoreBluetooth · MultipeerConnectivity (MPC)&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;Native radio APIs exposed via Swift bridge handlers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="NATIVE">
                    <mxGeometry x="760" y="45" width="340" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="PRIORITY" value="&lt;b&gt;DETERMINISTIC PRIORITY SELECTION · CAL.TR&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Tech: 5-rule deterministic algorithm (M5 Locked-in) · no probabilistic / no ML · RT-03 compliant&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;align=left;spacingLeft=8;spacingTop=4;container=1;collapsible=0;recursiveResize=0;expand=0;" vertex="1" parent="1">
                    <mxGeometry x="20" y="725" width="1140" height="370" as="geometry"/>
                </mxCell>
                <mxCell id="ROUTER" value="&lt;b&gt;Payload size +&lt;br/&gt;link health?&lt;/b&gt;&lt;br/&gt;&lt;i&gt;CAL.TR decision&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57c00;strokeWidth=1.5;fontSize=11;spacing=5;" vertex="1" parent="PRIORITY">
                    <mxGeometry x="470" y="50" width="200" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="BLE" value="&lt;b&gt;Tier 1 · BLE Mesh&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Primary · background discovery&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;~30–100 m · lowest latency&lt;br/&gt;Default for nearby peer comms" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="PRIORITY">
                    <mxGeometry x="40" y="220" width="340" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="WIFI" value="&lt;b&gt;Tier 1 · Wi-Fi Direct&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Fallback · on-demand&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;~50–200 m · higher bandwidth&lt;br/&gt;Used when BLE saturated or for large PCR" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="PRIORITY">
                    <mxGeometry x="400" y="220" width="340" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="LORA" value="&lt;b&gt;Tier 2 · LoRa Peripheral&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Long-range · paired-only&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;~1–15 km · GoTenna Mesh / Meshtastic&lt;br/&gt;Requires EXT-9007 peripheral paired via BLE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="PRIORITY">
                    <mxGeometry x="760" y="220" width="340" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="LORA_ON" value="&lt;b&gt;LoRa ONBOARDING · WFD-5126&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Tech: 4-state wireframe authoritative flow&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Triggered when LoRa peripheral connects mid-session&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b2dfdb;strokeColor=#00695c;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;align=left;spacingLeft=8;spacingTop=4;container=1;collapsible=0;recursiveResize=0;expand=0;" vertex="1" parent="1">
                    <mxGeometry x="1180" y="80" width="600" height="820" as="geometry"/>
                </mxCell>
                <mxCell id="WF01" value="&lt;b&gt;TM-WF-01 · Disclosure&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;i&gt;Peripheral detected — awaiting user acknowledgement.&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;Disclosure of capabilities, range, battery impact." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="LORA_ON">
                    <mxGeometry x="170" y="70" width="260" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="WF02" value="&lt;b&gt;TM-WF-02 · Short-Range Pairing&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;i&gt;BLE pairing in progress.&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;Peripheral firmware/config exchange. Visual Calm progress indicator." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="LORA_ON">
                    <mxGeometry x="170" y="260" width="260" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="WF03" value="&lt;b&gt;TM-WF-03 · Hardware Detected · Active&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;i&gt;Peripheral healthy and registered with MTT as Tier-2 adapter.&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;Tier 2 LoRa now selectable by CAL.TR priority router." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="LORA_ON">
                    <mxGeometry x="170" y="450" width="260" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="WF04" value="&lt;b&gt;TM-WF-04 · Disconnected&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;i&gt;Peripheral unreachable.&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;Error displayed with retry path. Visual Calm copy — no alarming language." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="LORA_ON">
                    <mxGeometry x="170" y="640" width="260" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="OFFLINE" value="&lt;b&gt;SURVIVAL CORE PATHS · Zero network dependency&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;i&gt;All 3 active transport tiers (BLE Mesh · Wi-Fi Direct · LoRa) operate offline.&lt;/i&gt;&lt;br/&gt;&lt;i&gt;CAL never introduces cellular / cloud dependency into any Survival Core path (NAV · SOS · BackTrack).&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Spec authority:&lt;/b&gt; ESF-5026 §4 (Survival Core Isolation) · MAS-5126 (Offline Operation) · compliance-matrix.md §4" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=1.5;fontColor=#1b5e20;fontSize=10;spacing=5;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="1180" y="920" width="600" height="175" as="geometry"/>
                </mxCell>
