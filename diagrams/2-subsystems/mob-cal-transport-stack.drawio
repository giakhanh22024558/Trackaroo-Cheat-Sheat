                <mxCell id="TITLE" value="&lt;b&gt;MOB-1101 · CAL — Transport Stack (Flutter ⇄ Native ⇄ Radios + LoRa Onboarding)&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Tech: Flutter Dart + Swift iOS/Kotlin Android · MethodChannel boundary · ITransport adapter pattern · WFD-5126 LoRa onboarding wireframes&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Reduced scope — only transport-relevant cells shown. Companion to mob-cal-architectural-diagram.drawio (Component Arch + State Machine).&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="20" y="10" width="1760" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="APP" value="&lt;b&gt;FLUTTER APPLICATION LAYER · Experience Layer&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Tech: Flutter · Dart · CAL Engine owns 4 mandatory state flags&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;align=left;spacingLeft=8;spacingTop=4;container=1;collapsible=0;recursiveResize=0;expand=0;" vertex="1" parent="1">
                    <mxGeometry x="20" y="80" width="1140" height="380" as="geometry"/>
                </mxCell>
                <mxCell id="TM" value="&lt;i&gt;MOB-1001&lt;/i&gt; · &lt;b&gt;TrackMate UI&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Messaging + location UI · Primary CAL caller · invokes send(msg) and toggles session lifecycle&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;fontSize=10;spacing=5;" vertex="1" parent="APP">
                    <mxGeometry x="20" y="50" width="540" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="CAL" value="&lt;i&gt;MOB-1101&lt;/i&gt; · &lt;b&gt;CAL Engine · Comms Abstraction Layer&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;background-color:#ffe082;color:#000;padding:1px 4px;font-size:8px;&quot;&gt;satReady = FALSE · Inactive in Phase 1.&lt;/span&gt;&lt;br/&gt;&lt;i&gt;5 internal components — SFM · LMON · TR · QMGR · SPUB&lt;/i&gt;&lt;br/&gt;&lt;i&gt;Owns transport priority + 4 flags + UI state publication&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#555555;strokeWidth=1;dashed=1;dashPattern=3 2;fontSize=10;spacing=5;" vertex="1" parent="APP">
                    <mxGeometry x="580" y="50" width="540" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="FLAGS" value="&lt;b&gt;CAL State Flags · FSD-5126&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Owned by SFM · deterministic transitions only&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#0277bd;strokeWidth=1.5;verticalAlign=top;fontSize=11;fontStyle=1;align=left;spacingLeft=6;spacingTop=3;container=1;collapsible=0;recursiveResize=0;expand=0;" vertex="1" parent="APP">
                    <mxGeometry x="20" y="180" width="1100" height="180" as="geometry"/>
